# ============================================
# CONFIGURAÇÃO DE SERVIDOR
# ============================================
PORT=3000

# ============================================
# CONFIGURAÇÃO DO MONGODB
# ============================================
# String de conexão configurada (MongoDB Atlas)
MONGODB_URI=mongodb+srv://ApojeuB:Santa20*@cluster-biblioteca.fbxbfpp.mongodb.net/biblioteca?retryWrites=true&w=majority

# Credenciais do MongoDB (usadas apenas se você estiver rodando MongoDB localmente)
MONGO_ROOT_USER=Mister
MONGO_ROOT_PASSWORD=HelloWorldMisterOrths

# ============================================
# CONFIGURAÇÃO DE AUTENTICAÇÃO JWT
# ============================================
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d

# ============================================
# CONFIGURAÇÃO DE EMAIL (SMTP)
# ============================================
# Deixe em branco se não quiser usar envio de emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SUGGESTION_TO_EMAIL=
SUGGESTION_FROM_EMAIL=
